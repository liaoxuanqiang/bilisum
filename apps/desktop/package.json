{
  "name": "bilisum-desktop",
  "version": "1.19.2",
  "private": true,
  "description": "BiliSum desktop shell powered by React, Vite, and Electron.",
  "main": "dist-electron/main.js",
  "author": {
    "name": "lycohana"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:macUI": "concurrently -k \"npm:dev:renderer\" \"wait-on tcp:3000 && npm run build:electron && cross-env BILISUM_RENDERER_URL=http://127.0.0.1:3000 BILISUM_DEV_PLATFORM=darwin electron ./dist-electron/main.js\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on tcp:3000 && npm run build:electron && cross-env BILISUM_RENDERER_URL=http://127.0.0.1:3000 electron ./dist-electron/main.js",
    "test": "node --experimental-strip-types test/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:renderer": "vite build --config vite.config.ts",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "package:win": "powershell -ExecutionPolicy Bypass -File ../../packaging/desktop/build_windows.ps1",
    "package:win-notfront": "powershell -ExecutionPolicy Bypass -File ../../packaging/desktop/build_windows.ps1 -SkipPrebuild",
    "package:mac": "bash ../../packaging/desktop/build_macos.sh",
    "package:mac-notfront": "bash ../../packaging/desktop/build_macos.sh --skip-prebuild"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.11.0",
    "electron-updater": "^6.8.9",
    "html-to-image": "^1.11.13",
    "katex": "^0.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-arborist": "^3.10.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "^5.8.2",
    "vite": "^8.0.16",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.bilisum.desktop",
    "productName": "BiliSum",
    "artifactName": "${productName}-${version}-${os}-${arch}-Setup.${ext}",
    "directories": {
      "output": "../../dist/desktop"
    },
    "files": [
      "dist-electron/**/*",
      "announcement.md"
    ],
    "extraResources": [
      {
        "from": "../../dist/BiliSum",
        "to": "backend/BiliSum"
      },
      {
        "from": "../../apps/desktop/build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
      "icon": "../../apps/desktop/build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "sign": false,
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../../apps/desktop/build/icon.ico",
      "signAndEditExecutable": true,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "perMachine": false,
      "installerIcon": "../../apps/desktop/build/icon.ico",
      "uninstallerIcon": "../../apps/desktop/build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "lycohana",
      "repo": "BiliSum",
      "releaseType": "release"
    }
  }
}
